{
  "name": "@workspace/scripts",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "catalog:tfda188": "tsx ./src/catalog-import.ts --dry-run",
    "catalog:tfda188:write-staging": "tsx ./src/catalog-import.ts --write-staging",
    "catalog:off-taiwan": "tsx ./src/open-food-facts-import.ts --dry-run --country=Taiwan --max-pages=1 --page-size=100",
    "catalog:off-taiwan:write-staging": "tsx ./src/open-food-facts-import.ts --write-staging --country=Taiwan --max-pages=1 --page-size=100",
    "catalog:prioritize": "tsx ./src/catalog-prioritize.ts --limit=100",
    "catalog:prioritize:write-queue": "tsx ./src/catalog-prioritize.ts --write-queue --limit=100",
    "catalog:test": "tsx --test ./src/catalog/*.test.ts",
    "hello": "tsx ./src/hello.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@workspace/db": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "tsx": "catalog:"
  }
}
