{
  "name": "@workspace/scripts",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "catalog:tfda188": "tsx ./src/catalog-import.ts --dry-run",
    "catalog:tfda188:write-staging": "tsx ./src/catalog-import.ts --write-staging",
    "catalog:off-taiwan": "tsx ./src/open-food-facts-import.ts --dry-run --country=Taiwan --max-pages=1 --page-size=100",
    "catalog:off-taiwan:write-staging": "tsx ./src/open-food-facts-import.ts --write-staging --country=Taiwan --max-pages=500 --page-size=100",
    "catalog:off-taiwan:export": "tsx ./src/open-food-facts-export-import.ts --dry-run",
    "catalog:off-taiwan:export:write-staging": "tsx ./src/open-food-facts-export-import.ts --write-staging",
    "catalog:7eleven": "tsx ./src/seven-eleven-import.ts --dry-run",
    "catalog:7eleven:write-staging": "tsx ./src/seven-eleven-import.ts --write-staging",
    "catalog:prioritize": "tsx ./src/catalog-prioritize.ts --limit=100",
    "catalog:prioritize:write-queue": "tsx ./src/catalog-prioritize.ts --write-queue --limit=100",
    "science:sync": "tsx ./src/scientific-evidence-import.ts --dry-run --max-pages=1 --page-size=100",
    "science:sync:write-staging": "tsx ./src/scientific-evidence-import.ts --write-staging --topics-from-db --max-pages=1000 --page-size=100",
    "science:sync:reference": "tsx ./src/scientific-evidence-import.ts --dry-run --include-preclinical --max-pages=1 --page-size=100",
    "science:sync:reference:write-staging": "tsx ./src/scientific-evidence-import.ts --write-staging --topics-from-db --include-preclinical --max-pages=1000 --page-size=100",
    "science:integrity": "tsx ./src/scientific-integrity-sync.ts --dry-run",
    "science:integrity:write-staging": "tsx ./src/scientific-integrity-sync.ts --write-staging",
    "data:promote": "tsx ./src/promote-staging-data.ts --dry-run",
    "data:promote:write-production": "tsx ./src/promote-staging-data.ts --write-production",
    "catalog:test": "tsx --test ./src/catalog/*.test.ts",
    "science:test": "tsx --test ./src/science/*.test.ts",
    "hello": "tsx ./src/hello.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@workspace/db": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "tsx": "catalog:"
  }
}
